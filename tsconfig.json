{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@app/*": ["./app/*"],
      "@features/*": ["./features/*"],
      "@shared/*": ["./shared/*"],
      "@design-system/*": ["./design-system/*"],
      "@config/*": ["./config/*"],
      "@constants/*": ["./constants/*"],
      "@lib/*": ["./lib/*"]
    },
    "types": ["nativewind/types", "node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "global.css"
  ]
}
