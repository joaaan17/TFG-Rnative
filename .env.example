# =====================================================
# Variables de entorno del SERVIDOR (Railway / Render)
# Copia este archivo como .env y rellena los valores.
# NUNCA commits el .env real al repositorio.
# =====================================================

# --- Base de Datos MongoDB Atlas ---
AUTH_DB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.mongodb.net/?appName=TFGCluster

# --- Seguridad JWT (tokens sin expiración: la sesión dura hasta signOut en la app) ---
AUTH_JWT_SECRET=frase-secreta-muy-larga-y-aleatoria-123456

# --- Hashing Bcrypt ---
AUTH_BCRYPT_ROUNDS=10

# --- OpenAI (consultorio IA) ---
OPENAI_API_KEY=sk-proj-...

# --- NewsAPI (noticias educativas) ---
NEWS_API_KEY=tu-clave-newsapi
# Opcional: horas entre refrescos de titulares (mismo juego de 2 noticias para todos). Por defecto 12 (dos veces al día).
# NEWS_HEADLINES_TTL_HOURS=12

# --- Correo SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=contraseña-de-aplicación
MAIL_MODE=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=tucorreo@gmail.com
MAIL_PASS=contraseña-de-aplicación
MAIL_FROM=tucorreo@gmail.com

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- CORS: dominios permitidos en producción (comma-separated) ---
# Añade el dominio de Vercel una vez desplegado el frontend.
ALLOWED_ORIGINS=https://TU-APP.vercel.app

# =====================================================
# Variables de entorno del FRONTEND (Vercel / Expo)
# Añade EXPO_PUBLIC_API_URL en Vercel → Settings → Environment Variables
# =====================================================
EXPO_PUBLIC_API_URL=https://TU-APP.railway.app
